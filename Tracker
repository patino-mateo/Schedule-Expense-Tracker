        self.save_btn.clicked.connect(self.save_all_data)
        action_buttons.addStretch(); action_buttons.addWidget(self.save_btn)
        main_layout.addLayout(action_buttons)
        self.load_existing_data()

    def provide_table_context_menu(self, pos):
        row = self.finance_table.currentRow()
        if row >= 0:
            menu = QMenu(self)
            delete_action = menu.addAction("❌ Delete Entry Selection")
            if menu.exec(self.finance_table.viewport().mapToGlobal(pos)) == delete_action:
                self.finance_table.removeRow(row)

    def open_color_picker(self):
        initial = QColor(self.selected_color_hex) if self.selected_color_hex else QColor("#121212")
        color = QColorDialog.getColor(initial, self, "Pick Day Identifier Color")
        if color.isValid():
            self.selected_color_hex = color.name()
            self.color_preview.setStyleSheet(f"background-color: {self.selected_color_hex}; border: 1px solid #fff;")

    def add_transaction(self):
        category = self.cat_input.text().strip().lower()
        amount_txt = self.amt_input.text().strip()
        trans_type = self.type_input.currentText()
        if category and amount_txt:
            try:
                amount = float(amount_txt)
                row_idx = self.finance_table.rowCount()
                self.finance_table.insertRow(row_idx)
                self.finance_table.setItem(row_idx, 0, QTableWidgetItem(category))
                self.finance_table.setItem(row_idx, 1, QTableWidgetItem(f"{amount:.2f}"))
                self.finance_table.setItem(row_idx, 2, QTableWidgetItem(trans_type))
                self.cat_input.clear(); self.amt_input.clear()
            except ValueError: pass

    def load_existing_data(self):
        conn = sqlite3.connect("schedule_budget_tracker.db")
        cursor = conn.cursor()
        cursor.execute("SELECT description, color_hex FROM daily_descriptions WHERE date = ?", (self.date_str,))
        desc_row = cursor.fetchone()
        if desc_row:
            self.day_description.setText(desc_row[0] if desc_row[0] else "")
            if desc_row[1]:
                self.selected_color_hex = desc_row[1]
                self.color_preview.setStyleSheet(f"background-color: {self.selected_color_hex}; border: 1px solid #fff;")
        cursor.execute("SELECT category, amount, type FROM daily_finances WHERE date = ?", (self.date_str,))
        for row_idx, row in enumerate(cursor.fetchall()):
            self.finance_table.insertRow(row_idx)
            self.finance_table.setItem(row_idx, 0, QTableWidgetItem(str(row[0])))
            self.finance_table.setItem(row_idx, 1, QTableWidgetItem(f"{row[1]:.2f}"))
            self.finance_table.setItem(row_idx, 2, QTableWidgetItem(str(row[2])))
        conn.close()

    def save_all_data(self):
        conn = sqlite3.connect("schedule_budget_tracker.db")
        cursor = conn.cursor()
        desc_text = self.day_description.toPlainText().strip()
        if desc_text or self.selected_color_hex:
            cursor.execute("INSERT OR REPLACE INTO daily_descriptions (date, description, color_hex) VALUES (?, ?, ?)", (self.date_str, desc_text, self.selected_color_hex))
        else:
            cursor.execute("DELETE FROM daily_descriptions WHERE date = ?", (self.date_str,))
        cursor.execute("DELETE FROM daily_finances WHERE date = ?", (self.date_str,))
        for row in range(self.finance_table.rowCount()):
            cat = self.finance_table.item(row, 0).text()
            amt = float(self.finance_table.item(row, 1).text())
            ttype = self.finance_table.item(row, 2).text()
            cursor.execute("INSERT INTO daily_finances (date, category, amount, type) VALUES (?, ?, ?, ?)", (self.date_str, cat, amt, ttype))
        conn.commit()
        conn.close()
        self.accept()

