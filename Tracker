# --- DATABASE ENGINE INIT ---
def init_db():
    conn = sqlite3.connect("schedule_budget_tracker.db")
    cursor = conn.cursor()
    cursor.execute('''CREATE TABLE IF NOT EXISTS daily_descriptions (
                        date TEXT PRIMARY KEY, description TEXT, color_hex TEXT)''')
    cursor.execute('''CREATE TABLE IF NOT EXISTS daily_finances (
                        id INTEGER PRIMARY KEY AUTOINCREMENT, date TEXT,
                        category TEXT, amount REAL, type TEXT)''')
    cursor.execute('''CREATE TABLE IF NOT EXISTS budget_caps (
                        category TEXT PRIMARY KEY, max_amount REAL)''')
    cursor.execute('''CREATE TABLE IF NOT EXISTS recurring_rules (
                        id INTEGER PRIMARY KEY AUTOINCREMENT, category TEXT,
                        amount REAL, type TEXT, frequency TEXT, start_date TEXT)''')
    cursor.execute('''CREATE TABLE IF NOT EXISTS savings_goals (
                        name TEXT PRIMARY KEY, target_amount REAL, current_saved REAL)''')
    conn.commit()
    conn.close()

# --- CUSTOM GRAPHICS WIDGETS ---
class ProgressRingWidget(QWidget):
    def __init__(self, title="Spent", parent=None):
        super().__init__(parent)
        self.setFixedSize(180, 180)
        self.percentage = 0.0
        self.title = title

    def set_value(self, numerator, denominator):
        if denominator > 0:
            self.percentage = min(numerator / denominator, 1.0)
        else:
            self.percentage = 1.0 if numerator > 0 else 0.0
        self.update()

    def paintEvent(self, event):
        painter = QPainter(self)
        painter.setRenderHint(QPainter.RenderHint.Antialiasing)
        rect = QRect(10, 10, 160, 160)
        
        painter.setPen(QPen(QColor("#2D2D2D"), 12, Qt.PenStyle.SolidLine, Qt.PenCapStyle.RoundCap))
        painter.drawEllipse(rect)
        
        accent = QColor("#00ADB5") if self.title == "Saved" else (QColor("#FF4A4A") if self.percentage > 0.85 else QColor("#9B5DE5"))
        painter.setPen(QPen(accent, 12, Qt.PenStyle.SolidLine, Qt.PenCapStyle.RoundCap))
        
        start_angle = 90 * 16
        span_angle = int(-self.percentage * 360 * 16)
        painter.drawArc(rect, start_angle, span_angle)
        
        painter.setPen(QColor("#E0E0E0"))
        painter.setFont(QFont("Segoe UI", 11, QFont.Weight.Bold))
        painter.drawText(rect, Qt.AlignmentFlag.AlignCenter, f"{int(self.percentage * 100)}%\n{self.title}")

class CustomPieChartWidget(QWidget):
    def __init__(self, parent=None):
        super().__init__(parent)
        self.setFixedSize(180, 180)
        self.slices = {}

    def set_data(self, data_dict):
        self.slices = data_dict
        self.update()

    def paintEvent(self, event):
        painter = QPainter(self)
        painter.setRenderHint(QPainter.RenderHint.Antialiasing)
        rect = QRect(10, 10, 160, 160)
        total = sum(self.slices.values())
        
        if total == 0:
            painter.setBrush(QBrush(QColor("#2D2D2D")))
            painter.setPen(Qt.PenStyle.NoPen)
            painter.drawEllipse(rect)
            painter.setPen(QColor("#888888"))
            painter.setFont(QFont("Segoe UI", 10))
            painter.drawText(rect, Qt.AlignmentFlag.AlignCenter, "No Expense\nData")
            return

        colors = ["#00ADB5", "#FF4A4A", "#FFB400", "#9B5DE5", "#F15BB5", "#00F5D4"]
        start_angle = 0
        for idx, (category, val) in enumerate(self.slices.items()):
            painter.setBrush(QBrush(QColor(colors[idx % len(colors)])))
            painter.setPen(Qt.PenStyle.NoPen)
            span_angle = int((val / total) * 360 * 16)
            painter.drawPie(rect, start_angle, span_angle)
            start_angle += span_angle

# --- KEYBOARD INTERACTIVE TABLE EXTENSION ---
class InteractiveTableWidget(QTableWidget):
    """Custom Table to handle native keyboard Delete key overrides."""
    def __init__(self, rows, cols, parent=None):
        super().__init__(rows, cols, parent)
        self.delete_callback = None

    def set_delete_callback(self, callback):
        self.delete_callback = callback

    def keyPressEvent(self, event: QKeyEvent):
        if event.key() == Qt.Key.Key_Delete:
            row = self.currentRow()
            if row >= 0 and self.delete_callback:
                self.delete_callback(row)
        else:
            super().keyPressEvent(event)

# --- CUSTOM CALENDAR OVERLAYS ---
class AdvancedCustomCalendar(QCalendarWidget):
    def __init__(self, parent=None):
        super().__init__(parent)
        self.show_amounts = False
        self.highlighted_dates = set()
        self.apply_custom_week_header_label()

    def apply_custom_week_header_label(self):
        view = self.findChild(QTableView)
        if view:
            model = view.model()
            if model: model.setHeaderData(0, Qt.Orientation.Horizontal, "Week")

    def set_amounts_visible(self, visible): self.show_amounts = visible
    def set_search_highlights(self, dates_set): self.highlighted_dates = dates_set

    def paintCell(self, painter, rect, date):
        date_str = date.toString("MM/dd/yyyy")
        conn = sqlite3.connect("schedule_budget_tracker.db")
        cursor = conn.cursor()
        cursor.execute("SELECT color_hex FROM daily_descriptions WHERE date = ?", (date_str,))
        color_row = cursor.fetchone()
        cursor.execute("SELECT 1 FROM daily_finances WHERE date = ? AND type = 'income' LIMIT 1", (date_str,))
        has_income = cursor.fetchone() is not None
        cursor.execute("SELECT 1 FROM daily_finances WHERE date = ? AND type = 'expense' LIMIT 1", (date_str,))
        has_expense = cursor.fetchone() is not None
        conn.close()
        
        has_activity = color_row is not None and color_row[0] is not None and color_row[0] != ""

        painter.save()
        painter.setRenderHint(QPainter.RenderHint.Antialiasing)
        painter.setBrush(QBrush(QColor("#121212")))
        painter.setPen(Qt.PenStyle.NoPen)
        painter.drawRect(rect)

        if date_str in self.highlighted_dates:
            painter.setPen(QPen(QColor("#FFB400"), 2))
            painter.drawRect(rect.adjusted(1, 1, -1, -1))

        if has_activity:
            painter.setBrush(QBrush(QColor(color_row[0])))
            painter.setPen(Qt.PenStyle.NoPen)
            triangle = QPolygon([QPoint(rect.right() - 12, rect.top()), QPoint(rect.right(), rect.top()), QPoint(rect.right(), rect.top() + 12)])
            painter.drawPolygon(triangle)

        painter.setPen(QColor("#E0E0E0") if date.month() == self.monthShown() else QColor("#555555"))
        painter.setFont(QFont("Segoe UI", 10))
        painter.drawText(rect, Qt.AlignmentFlag.AlignCenter, str(date.day()))
        painter.restore()
        
        if self.show_amounts:
            painter.save()
            painter.setFont(QFont("Segoe UI", 10, QFont.Weight.Bold))
            if has_income and has_expense:
                painter.setPen(QColor("#00FF66"))
                painter.drawText(QRect(rect.left(), rect.bottom() - 18, rect.width() - 12, 18), Qt.AlignmentFlag.AlignRight | Qt.AlignmentFlag.AlignBottom, "$")
                painter.setPen(QColor("#FF4A4A"))
                painter.drawText(QRect(rect.left(), rect.bottom() - 18, rect.width() - 3, 18), Qt.AlignmentFlag.AlignRight | Qt.AlignmentFlag.AlignBottom, "$")
            elif has_income:
                painter.setPen(QColor("#00FF66"))
                painter.drawText(QRect(rect.left(), rect.bottom() - 18, rect.width() - 3, 18), Qt.AlignmentFlag.AlignRight | Qt.AlignmentFlag.AlignBottom, "$")
            elif has_expense:
                painter.setPen(QColor("#FF4A4A"))
                painter.drawText(QRect(rect.left(), rect.bottom() - 18, rect.width() - 3, 18), Qt.AlignmentFlag.AlignRight | Qt.AlignmentFlag.AlignBottom, "$")
            painter.restore()

