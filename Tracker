    def refresh_advanced_analytics_plots(self):
        """Feature 1 Execution Engine: Runs vector calculations to plot real-time trend charts."""
        conn = sqlite3.connect("schedule_budget_tracker.db")
        cursor = conn.cursor()
        cursor.execute("SELECT amount, type FROM daily_finances ORDER BY id ASC")
        rows = cursor.fetchall()
        
        # 1. Compute Running Historical Net Savings History curve
        running_net = 0.0
        y_data = []
        for amt, ttype in rows:
            if ttype == 'income': running_net += amt
            else: running_net -= amt
            y_data.append(running_net)
            
        self.trend_plot.clear()
        if y_data:
            self.trend_plot.plot(y_data, pen=pg.mkPen(color="#00ADB5", width=3), symbol='o', symbolSize=6, symbolBrush="#9B5DE5")
            
        # 2. Compute Bar Chart Matrix for Current Selected Month
        current_date = self.calendar.selectedDate()
        search_pattern = f"{current_date.toString('MM')}/%/{current_date.toString('yyyy')}"
        cursor.execute("SELECT category, SUM(amount) FROM daily_finances WHERE date LIKE ? AND type = 'expense' GROUP BY category", (search_pattern,))
        bar_rows = cursor.fetchall()
        conn.close()
        
        self.bar_plot.clear()
        if bar_rows:
            x_indices = list(range(len(bar_rows)))
            heights = [row[1] for row in bar_rows]
            labels = [row[0] for row in bar_rows]
            
            bar_item = pg.BarGraphItem(x=x_indices, height=heights, width=0.5, brush="#FF4A4A", pen="#121212")
            self.bar_plot.addItem(bar_item)
            
            # Label categorical strings along horizontal x-axis bounds manually
            ax = self.bar_plot.getAxis('bottom')
            ax.setTicks([[(i, labels[i]) for i in x_indices]])

