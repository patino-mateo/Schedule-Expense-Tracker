    def export_to_csv(self):
        path, _ = QFileDialog.getSaveFileName(self, "Export Data", "", "CSV Files (*.csv)")
        if path:
            conn = sqlite3.connect("schedule_budget_tracker.db")
            cursor = conn.cursor()
            cursor.execute("SELECT date, category, amount, type FROM daily_finances ORDER BY date DESC")
