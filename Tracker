    # --- ADVANCED LOGIC PIPELINES AUTOMATION INTERFACES ---
    def process_recurring_rules(self):
        conn = sqlite3.connect("schedule_budget_tracker.db")
        cursor = conn.cursor()
        cursor.execute("SELECT id, category, amount, type, frequency, start_date FROM recurring_rules")
        rules = cursor.fetchall()
        today = datetime.now().date()
        
        for r_id, cat, amt, ttype, freq, s_date_str in rules:
            start_date = datetime.strptime(s_date_str, "%Y-%m-%d").date()
            current_eval = start_date
            
            while current_eval <= today:
                date_formatted = current_eval.strftime("%m/%d/%Y")
                cursor.execute("SELECT 1 FROM daily_finances WHERE date = ? AND category = ? AND amount = ? AND type = ?", 
                               (date_formatted, cat, amt, ttype))
                if not cursor.fetchone():
                    cursor.execute("INSERT INTO daily_finances (date, category, amount, type) VALUES (?, ?, ?, ?)", 
                                   (date_formatted, cat, amt, ttype))
                
                if freq == "Daily": current_eval += timedelta(days=1)
                elif freq == "Weekly": current_eval += timedelta(weeks=1)
                elif freq == "Monthly":
                    days = 31 if current_eval.month in [1,3,5,7,8,10,12] else (30 if current_eval.month != 2 else (29 if current_eval.year % 4 == 0 else 28))
                    current_eval += timedelta(days=days)
                elif freq == "Yearly":
                    try: current_eval = current_eval.replace(year=current_eval.year + 1)
                    except ValueError: current_eval += timedelta(days=365)
        conn.commit()
        conn.close()

    def save_recurring_rule(self):
        cat = self.r_cat.text().strip().lower()
        try:
            amt = float(self.r_amt.text().strip())
            ttype = self.r_type.currentText()
            freq = self.r_freq.currentText()
            if cat:
                conn = sqlite3.connect("schedule_budget_tracker.db")
                cursor = conn.cursor()
                cursor.execute("INSERT INTO recurring_rules (category, amount, type, frequency, start_date) VALUES (?, ?, ?, ?, ?)",
                               (cat, amt, ttype, freq, datetime.now().strftime("%Y-%m-%d")))
                conn.commit(); conn.close()
                self.r_cat.clear(); self.r_amt.clear()
                self.refresh_automation_tab_metrics()
                self.process_recurring_rules()
        except ValueError: pass

    def save_savings_goal(self):
        name = self.g_name.text().strip()
        try:
            target = float(self.g_target.text().strip()) if self.g_target.text().strip() else None
            deposit = float(self.g_deposit.text().strip()) if self.g_deposit.text().strip() else 0.0
            if name:
                conn = sqlite3.connect("schedule_budget_tracker.db")
                cursor = conn.cursor()
                cursor.execute("SELECT target_amount, current_saved FROM savings_goals WHERE name = ?", (name,))
                row = cursor.fetchone()
                if row:
                    final_target = target if target is not None else row[0]
                    final_saved = row[1] + deposit
                else:
                    final_target = target if target is not None else 0.0
                    final_saved = deposit
                cursor.execute("INSERT OR REPLACE INTO savings_goals (name, target_amount, current_saved) VALUES (?, ?, ?)",
                               (name, final_target, final_saved))
                conn.commit(); conn.close()
                self.g_name.clear(); self.g_target.clear(); self.g_deposit.clear()
                self.refresh_automation_tab_metrics()
        except ValueError: pass

    def refresh_automation_tab_metrics(self):
        conn = sqlite3.connect("schedule_budget_tracker.db")
        cursor = conn.cursor()
        cursor.execute("SELECT category, amount, type, frequency FROM recurring_rules")
        self.recur_table.setRowCount(0)
        for idx, row in enumerate(cursor.fetchall()):
            self.recur_table.insertRow(idx)
            for c in range(4): self.recur_table.setItem(idx, c, QTableWidgetItem(str(row[c])))
            
        cursor.execute("SELECT name, current_saved, target_amount FROM savings_goals")
        self.goals_table.setRowCount(0)
        for idx, row in enumerate(cursor.fetchall()):
            self.goals_table.insertRow(idx)
            self.goals_table.setItem(idx, 0, QTableWidgetItem(str(row[0])))
            self.goals_table.setItem(idx, 1, QTableWidgetItem(f"${row[1]:,.2f}"))
            self.goals_table.setItem(idx, 2, QTableWidgetItem(f"${row[2]:,.2f}"))
        conn.close()

