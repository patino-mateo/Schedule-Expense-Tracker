    def refresh_budget_metrics(self):
        current_date = self.calendar.selectedDate()
        month_str = current_date.toString("MM")
        year_str = current_date.toString("yyyy")
        search_pattern = f"{month_str}/%/{year_str}"
        
        conn = sqlite3.connect("schedule_budget_tracker.db")
        cursor = conn.cursor()
        cursor.execute("SELECT SUM(amount) FROM daily_finances WHERE date LIKE ? AND type = 'income'", (search_pattern,))
        income = cursor.fetchone()[0] or 0.0
        cursor.execute("SELECT SUM(amount) FROM daily_finances WHERE date LIKE ? AND type = 'expense'", (search_pattern,))
        expenses = cursor.fetchone()[0] or 0.0
        cursor.execute("SELECT category, SUM(amount) FROM daily_finances WHERE date LIKE ? AND type = 'expense' GROUP BY category", (search_pattern,))
        category_splits = {row[0]: row[1] for row in cursor.fetchall()}
        
        cursor.execute("SELECT category, max_amount FROM budget_caps")
        configured_caps = cursor.fetchall()
        self.caps_table.setRowCount(0)
        for row_idx, (cat, cap_limit) in enumerate(configured_caps):
            cursor.execute("SELECT SUM(amount) FROM daily_finances WHERE date LIKE ? AND type = 'expense' AND category = ?", (search_pattern, cat))
            current_spent = cursor.fetchone()[0] or 0.0
            self.caps_table.insertRow(row_idx)
            self.caps_table.setItem(row_idx, 0, QTableWidgetItem(cat))
            self.caps_table.setItem(row_idx, 1, QTableWidgetItem(f"${current_spent:,.2f}"))
            self.caps_table.setItem(row_idx, 2, QTableWidgetItem(f"${cap_limit:,.2f}"))
            if current_spent > cap_limit: self.caps_table.item(row_idx, 1).setForeground(QColor("#FF4A4A"))
            
        cursor.execute("SELECT SUM(current_saved), SUM(target_amount) FROM savings_goals")
        savings_row = cursor.fetchone()
        total_saved = savings_row[0] or 0.0
        total_savings_target = savings_row[1] or 0.0
        conn.close()
        
        self.title_lbl.setText(f"<h2>Overview for {current_date.toString('MMMM yyyy')}</h2>")
        self.income_lbl.setText(f"Total Monthly Income: <span style='color:#00FF66;'>${income:,.2f}</span>")
        self.expense_lbl.setText(f"Total Monthly Expenses: <span style='color:#FF4A4A;'>${expenses:,.2f}</span>")
        net = income - expenses
        self.net_lbl.setText(f"Net Balance: <span style='color:{'#00FF66;' if net >= 0 else '#FF4A4A;'}'>${net:,.2f}</span>")
        
        self.progress_ring.set_value(expenses, income)
        self.savings_ring.set_value(total_saved, total_savings_target)
        self.pie_chart.set_data(category_splits)
        self.drill_down_table.setRowCount(0)

